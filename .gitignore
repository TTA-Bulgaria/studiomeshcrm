# .gitignore for Agency CRM (Root)

# --- Claude Code local settings (contains internal tool permissions, not for VCS) ---
.claude/settings.local.json

# --- Environment ---
.env
.env.local
.env.*.local
*.env
# (Explicitly include example files if needed)
!.env.example

# --- .NET (Backend) ---
**/appsettings.Development.json
**/appsettings.Production.json
**/bin/
**/obj/
**/App_Data/
**/user-secrets.json
*.user
*.suo
*.userosscache
*.sln.docstates
.vs/
.vscode/

# --- Node.js / Next.js (Frontend) ---
**/node_modules/
**/.next/
**/out/
**/dist/
**/build/
**/coverage/
.vercel
**/*.tsbuildinfo
**/next-env.d.ts

# --- OS / IDE ---
.DS_Store
Thumbs.db
*.bak
*.tmp
*.temp
.idea/
.project
.settings/

# --- Logs ---
*.log
**/logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Databases ---
**/postgres-data/
*.db
*.sqlite

# --- Local .NET SDK & Scripts (Do Not Push) ---
.dotnet/
dotnet-install.ps1
ef_migrate*.ps1
login_error.json
test_results*.txt
